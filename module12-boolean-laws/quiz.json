      "choices": [
        "B",
        "A·B",
        "A",
        "1"
      ],
      "answer": 2,
      "explain": "A absorbs the redundant A·B term."
    },
    {
      "id": "q3",
      "type": "multiple_choice",
      "prompt": "Complement: A·A' equals…",
      "choices": [
        "0",
        "1",
        "A",
        "A'"
      ],
      "answer": 0,
      "explain": "A and its complement cannot both be true."
    },
